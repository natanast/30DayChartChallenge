# clean data ------
# A. The Triple Filter: One Indicator, One Lens, One Year
dt_clean <- dt[Indicator == "DIARCARE" & Stratifier == "WIQ"]
View(dt_clean)
# B. Get only the extremes (Poorest vs Richest) to see the 'Relationship'
dt_clean <- dt_clean[Level %in% c("Poorest", "Richest")]
# C. Keep only the most recent year per country to avoid line-crossing
dt_clean <- dt_clean[, .SD[which.max(`Latest Year`)], by = .(`Countries and areas`, Level)]
# D. Pick 6 countries to show a variety of 'Relationships'
# (Some with big gaps, some with small gaps)
target_countries <- c("Sierra Leone", "Nigeria", "Pakistan", "Indonesia", "Bangladesh", "Afghanistan")
dt_plot <- dt_clean[`Countries and areas` %in% target_countries]
# E. Order the Level for the X-axis
dt_plot[, Level := factor(Level, levels = c("Poorest", "Richest"))]
# 4. Plot -----------------------------------------------------------------
gr <- ggplot(dt_plot, aes(x = Level, y = Value, group = `Countries and areas`)) +
# Facet by country - this creates the 'different' look you want
facet_wrap(~`Countries and areas`, ncol = 3) +
# The Relationship Line
geom_line(aes(color = `Countries and areas`), linewidth = 1.5, alpha = 0.8) +
# The Points
geom_point(aes(color = `Countries and areas`), size = 4, fill = "white", shape = 21, stroke = 1.5) +
# Value Labels
geom_text(aes(label = paste0(round(Value), "%")), vjust = -1.5,
family = "Candara", fontface = "bold", size = 3.5) +
scale_color_manual(values = c("#b24745", "#678e9f", "#a8b2ba", "#5a5a5a", "#d18d8d", "#8d99ae")) +
scale_y_continuous(limits = c(0, 110)) + # Extra space for labels
labs(
title = "The Relationship between Wealth and Survival",
subtitle = "How care-seeking for children varies between the **Poorest** and **Richest** households.",
x = NULL,
y = "% Children Receiving Care (ORS)",
caption = "30DayChartChallenge 2026: <b> Day 17 (Relationships)</b> | Source: <b>UNICEF</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
