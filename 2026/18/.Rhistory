# load libraries -------
library(data.table)
library(ggplot2)
library(stringr)
library(ggtext)
library(extrafont)
library(colorspace)
# load data ------
dt <- fread("Child-Dataset-unicef-November-2024.csv")
dt |> head()
# A. Filter for 'National' level data only (essential for scatter plots)
dt_clean <- dt[Stratifier == "National"]
# B. Get the most recent year for each country and indicator
dt_clean <- dt_clean[, .SD[which.max(`Latest Year`)], by = .(`Countries and areas`, Indicator)]
# C. Pivot the data to get Indicators as Columns
# This creates a table where each row is a country, and columns are the health metrics
dt_wide <- dcast(dt_clean, `Countries and areas` + `ISO Code` ~ Indicator, value.var = "Value")
# D. Clean column names for the plot
# Based on common UNICEF codes: DIARCARE is often Diarrhoea Care
# Check your names(dt_wide) if these differ!
setnames(dt_wide, old = "DIARCARE", new = "diar_care", skip_absent = TRUE)
# Let's find the other main indicator (likely Malaria related)
# For this example, I'll assume the second column is the 'malaria' variable
other_ind <- names(dt_wide)[4]
setnames(dt_wide, old = other_ind, new = "malaria_val")
# E. Define Colors (Using your Valentine palette)
dt_wide[, status := "Global Average"]
dt_wide[diar_care < 30 & malaria_val > 50, status := "High Burden"]
cols <- c(
"High Burden"    = "#b24745", # Your Red
"Global Average" = "#a8b2ba"  # Your Grey
)
# 4. Plot -----------------------------------------------------------------
gr <- ggplot(dt_wide, aes(x = diar_care, y = malaria_val)) +
# Relationship trend line
geom_smooth(method = "lm", color = "white", linewidth = 1.5, se = FALSE) +
geom_smooth(method = "lm", color = "grey70", linetype = "dashed", linewidth = 0.5, se = FALSE) +
# Points
geom_point(
aes(fill = status),
shape = 21, color = "white", size = 4, stroke = 0.5, alpha = 0.8
) +
# Labels (Matching your ggrepel style)
geom_text_repel(
data = dt_wide[status == "High Burden" | `Countries and areas` %in% c("India", "Nigeria")],
aes(label = `Countries and areas`, color = status),
family = "Candara", fontface = "bold", size = 4,
box.padding = 0.5
) +
scale_fill_manual(values = cols) +
scale_color_manual(values = cols) +
labs(
title = "The Health Access Relationship",
subtitle = "Correlation between **Diarrhoea Care Seeking** and **Malaria Burden** in children.",
x = "% Children Receiving Diarrhoea Care (ORS)",
y = "Malaria Incidence / Burden",
caption = "30DayChartChallenge 2026: <b> Day 17 (Relationships)</b> | Source: <b>UNICEF (Kaggle)</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
plot.background = element_rect(fill = "#e4e4e3", color = NA),
panel.grid.major = element_line(linewidth = 0.3, color = "grey85"),
panel.grid.minor = element_blank(),
plot.title = element_markdown(size = 22, face = "bold", hjust = 0.5, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 13, hjust = 0.5, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, hjust = 1, color = "grey40"),
axis.title = element_text(size = 11, face = "bold", color = "grey20"),
plot.margin = margin(20, 20, 20, 20)
)
# 5. Save -----------------------------------------------------------------
ggsave(
plot = gr, filename = "Day17_UNICEF_Health.png",
width = 9, height = 9, units = "in", dpi = 600
)
gr
# Filter for Diarrhoea Care seeking and compare Urban vs Rural
dt_gap <- dt[Indicator == "DIARCARE" & Stratifier %in% c("Urban", "Rural")]
# Pivot to get Urban and Rural in separate columns
dt_wide <- dcast(dt_gap, `Countries and areas` ~ Stratifier, value.var = "Value")
# Remove rows with missing gaps and calculate the difference
dt_wide <- dt_wide[!is.na(Urban) & !is.na(Rural)]
dt_wide[, gap := Urban - Rural]
View(dt)
# 2. Load data ------------------------------------------------------------
dt <- fread("Malaria_and_Diarrhoea_Dataset.csv")
# FIX: Filter by 'Level' instead of 'Stratifier'
dt_gap <- dt[Indicator == "DIARCARE" & Level %in% c("Urban", "Rural")]
# Pivot: Each country gets one row, Urban and Rural become columns
dt_wide <- dcast(dt_gap, `Countries and areas` ~ Level, value.var = "Value")
# Check: If dcast worked, you should now have columns named 'Urban' and 'Rural'
# We remove NAs to ensure we only plot countries with both data points
dt_wide <- dt_wide[!is.na(Urban) & !is.na(Rural)]
# Calculate the 'Relationship' (the gap)
dt_wide[, gap := Urban - Rural]
# Select top 20 gaps to keep the chart clean and readable
dt_plot <- dt_wide[order(-gap)][1:20]
dt_plot[, `Countries and areas` := reorder(`Countries and areas`, Urban)]
# 4. Plot -----------------------------------------------------------------
gr <- ggplot(dt_plot) +
# The 'Relationship' bar (the gap between groups)
geom_segment(
aes(x = Rural, xend = Urban, y = `Countries and areas`, yend = `Countries and areas`),
color = "grey80", linewidth = 1.5
) +
# Rural points (Red - your signature Jewelry color)
geom_point(aes(x = Rural, y = `Countries and areas`), color = "#b24745", size = 4) +
# Urban points (Blue - your signature Evening Out color)
geom_point(aes(x = Urban, y = `Countries and areas`), color = "#678e9f", size = 4) +
# Simple direct labels for the first row to act as a legend
geom_text(data = dt_plot[1], aes(x = Rural, y = `Countries and areas`, label = "RURAL"),
vjust = -1.8, size = 3.5, family = "Candara", fontface = "bold", color = "#b24745") +
geom_text(data = dt_plot[1], aes(x = Urban, y = `Countries and areas`, label = "URBAN"),
vjust = -1.8, size = 3.5, family = "Candara", fontface = "bold", color = "#678e9f") +
scale_x_continuous(labels = function(x) paste0(x, "%"), limits = c(0, 100)) +
labs(
title = "The Relationship of Inequality",
subtitle = "The gap in **Diarrhoea Care Seeking** between Urban and Rural households.",
x = "% Children Receiving Oral Rehydration Salts (ORS)",
y = NULL,
caption = "30DayChartChallenge 2026: <b> Day 17 (Relationships)</b> | Source: <b>UNICEF</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
plot.background = element_rect(fill = "#e4e4e3", color = NA),
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(linewidth = 0.3, color = "grey85"),
panel.grid.minor = element_blank(),
plot.title = element_markdown(size = 22, face = "bold", margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 13, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, hjust = 1, color = "grey40"),
axis.text.y = element_text(size = 11, face = "bold", color = "grey20"),
axis.title.x = element_text(size = 10, face = "bold", margin = margin(t = 15), color = "grey30"),
plot.margin = margin(20, 30, 20, 20)
)
gr
