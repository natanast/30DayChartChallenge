dt_heat <- dt[Indicator == "MALARIA" & Stratifier == "WIQ"]
dt_heat <- dt_heat[, .(Avg_Value = mean(Value, na.rm = TRUE)),
by = .(`UNICEF Reporting Region`, Level)]
# 2. Order the levels
dt_heat[, Level := factor(Level, levels = c("Poorest", "Second", "Middle", "Fourth", "Richest"))]
# 3. Plot
ggplot(dt_heat, aes(x = Level, y = `UNICEF Reporting Region`, fill = Avg_Value)) +
geom_tile(color = "white", size = 0.5) +
scale_fill_gradient(low = "#a8b2ba", high = "#b24745") + # Grey to Red
labs(title = "The Regional Wealth-Malaria Relationship",
subtitle = "Average malaria incidence across wealth quintiles and regions.") +
theme_minimal(base_family = "Candara")
# Filter for the indicator you want to show (e.g., Malaria or Diarrhoea)
dt_heat <- dt[Indicator == "MALARIA" & Stratifier == "WIQ"]
# Calculate the average per region and quintile
dt_heat <- dt_heat[, .(Avg_Value = mean(Value, na.rm = TRUE)),
by = .(`UNICEF Reporting Region`, Level)]
# FIX: Order the levels properly
dt_heat[, Level := factor(Level, levels = c("Poorest", "Second", "Middle", "Fourth", "Richest"))]
# STRUCTURE: Sort regions by the 'Poorest' value to create a visual gradient
region_order <- dt_heat[Level == "Poorest"][order(Avg_Value)]$`UNICEF Reporting Region`
dt_heat[, `UNICEF Reporting Region` := factor(`UNICEF Reporting Region`, levels = region_order)]
# 2. Plot -----------------------------------------------------------------
gr <- ggplot(dt_heat, aes(x = Level, y = `UNICEF Reporting Region`, fill = Avg_Value)) +
# Use linewidth instead of size to fix the warning
geom_tile(color = "white", linewidth = 0.8) +
# Add text labels inside the tiles for clarity
geom_text(aes(label = round(Avg_Value, 1)),
family = "Candara", fontface = "bold",
color = ifelse(dt_heat$Avg_Value > 50, "white", "black"), size = 3) +
# Signature Palette: Grey to Red
scale_fill_gradient(low = "#e4e4e3", high = "#b24745", name = "Avg Incidence") +
labs(
title = "Malaria: The Geography of Poverty",
subtitle = "The relationship between **Wealth Quintiles** and **Malaria Incidence** by region.",
x = "Household Wealth",
y = NULL,
caption = "30DayChartChallenge 2026: <b> Day 17 (Relationships)</b> | Source: <b>UNICEF</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
plot.background = element_rect(fill = "#e4e4e3", color = NA),
panel.grid = element_blank(),
plot.title = element_markdown(size = 20, face = "bold", margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, hjust = 1, color = "grey40"),
axis.text.x = element_text(size = 10, face = "bold"),
axis.text.y = element_text(size = 10, face = "bold"),
legend.position = "right"
)
gr
