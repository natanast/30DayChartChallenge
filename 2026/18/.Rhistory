strip.text = element_text(size = 12, face = "bold", color = "black"),
panel.spacing = unit(2, "lines"),
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_line(linewidth = 0.3, color = "grey85"),
