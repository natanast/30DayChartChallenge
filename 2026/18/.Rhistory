# If the URL above is unavailable, you can use any CSV with ISO codes.
# For this example, let's simulate the structure based on UNICEF Warehouse:
dt <- fread(url)
# Indicator: Share of population with safely managed drinking water
water_url <- "https://ourworldindata.org/grapher/share-of-population-using-safely-managed-drinking-water.csv?v=1&csvType=full"
# Indicator: Under-five mortality rate
mortality_url <- "https://ourworldindata.org/grapher/child-mortality.csv?v=1&csvType=full"
dt_water <- fread(water_url)
dt_mort <- fread(mortality_url)
# A. Water Data (From unicefData package - worked in your first post)
# Fetching "Safely Managed Drinking Water"
df_water_raw <- unicefData(
indicator = "WS_PPL_W-SM",
latest = TRUE
)
dt_water <- as.data.table(df_water_raw)
# B. Mortality Data (Using the URL that worked for you)
mortality_url <- "https://ourworldindata.org/grapher/child-mortality.csv?v=1&csvType=full"
dt_mort <- fread(mortality_url)
# Rename columns for the merge
# unicefData uses 'iso3' and 'value'
# OWID mortality uses 'Code' and 'Child mortality rate...' (usually column 4)
setnames(dt_water, old = c("iso3", "value"), new = c("Code", "water_access"))
setnames(dt_mort, old = names(dt_mort)[4], new = "mortality_rate")
# Keep only 2022/2023 mortality data to match latest water data
dt_mort <- dt_mort[Year == 2022]
# Merge on Country Code
dt_final <- merge(dt_water, dt_mort, by = "Code")
# Filter out regional aggregates (like "UNICEF East Asia")
# Actual countries have 3-letter codes
dt_final <- dt_final[nchar(Code) == 3]
# Create status groups for your color palette
dt_final[, status := "Other"]
dt_final[water_access < 40 & mortality_rate > 70, status := "High Risk"]
dt_final[water_access > 95 & mortality_rate < 5, status := "Safe"]
col_palette <- c(
"High Risk" = "#b24745", # Red from your Valentine script
"Safe"      = "#678e9f", # Blue from your Valentine script
"Other"     = "#a8b2ba"  # Grey
)
# 4. Plot -----------------------------------------------------------------
gr <- ggplot(dt_final, aes(x = water_access, y = mortality_rate)) +
# Relationship trend line (using a log relationship)
geom_smooth(
method = "lm", formula = y ~ log(x),
color = "white", linewidth = 1.2, se = FALSE
) +
geom_smooth(
method = "lm", formula = y ~ log(x),
color = "grey60", linetype = "dashed", linewidth = 0.4, se = FALSE
) +
# Points
geom_point(
aes(fill = status, size = status),
shape = 21, color = "white", stroke = 0.5, alpha = 0.8
) +
# Label key countries (Relationship outliers)
geom_text_repel(
data = dt_final[status != "Other" | country %in% c("India", "Nigeria", "Indonesia")],
aes(label = country, color = status),
family = "Candara", fontface = "bold", size = 4,
box.padding = 0.6, segment.color = "grey50"
) +
scale_fill_manual(values = col_palette) +
scale_color_manual(values = col_palette) +
scale_size_manual(values = c("High Risk" = 5, "Safe" = 4, "Other" = 2.5)) +
labs(
title = "The Vital Relationship: Water & Survival",
subtitle = "Correlation between **Safe Water Access** and **Under-5 Mortality Rate** (2022).",
x = "% of Population with Safely Managed Drinking Water",
y = "Deaths per 1,000 Live Births",
caption = "30DayChartChallenge 2026: <b> Day 17 (Relationships)</b> | Source: <b>UNICEF Data Warehouse</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
plot.background = element_rect(fill = "#e4e4e3", color = NA),
panel.grid.major = element_line(linewidth = 0.3, color = "grey85"),
panel.grid.minor = element_blank(),
plot.title = element_markdown(size = 22, face = "bold", hjust = 0.5, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 13, hjust = 0.5, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, hjust = 1, color = "grey40"),
axis.title = element_text(size = 11, face = "bold", color = "grey20"),
plot.margin = margin(20, 20, 20, 20)
)
# 5. Save -----------------------------------------------------------------
ggsave(
plot = gr, filename = "Day17_UNICEF_Water_Relationship.png",
width = 9, height = 9, units = "in", dpi = 600
)
gr
