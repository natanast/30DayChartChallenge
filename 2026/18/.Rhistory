# 2. Load data ------------------------------------------------------------
dt <- fread("Malaria_and_Diarrhoea_Dataset.csv")
# Filter for Wealth Index Quintile (WIQ)
# This shows the relationship between money and health access
dt_wealth <- dt[Indicator == "DIARCARE" & Stratifier == "WIQ"]
# We need to order the wealth levels so they make sense on the X-axis
dt_wealth[, Level := factor(Level,
levels = c("Poorest", "Second", "Middle", "Fourth", "Richest"))]
# Let's pick a few countries from different income groups to avoid over-crowding
# and see the 'Relationship' clearly
target_countries <- c("Sierra Leone", "Nigeria", "Pakistan", "Indonesia", "Bangladesh")
dt_plot <- dt_wealth[Countries and areas %in% target_countries]
# Colors from your palette
cols <- c(
"Sierra Leone" = "#b24745", # Red
"Nigeria"      = "#678e9f", # Blue
"Indonesia"    = "#a8b2ba", # Grey
"Pakistan"     = "#5a5a5a", # Dark Grey
"Bangladesh"   = "#d18d8d"  # Light Red
)
# 4. Plot -----------------------------------------------------------------
gr <- ggplot(dt_plot, aes(x = Level, y = Value, group = `Countries and areas`, color = `Countries and areas`)) +
# Add lines to show the 'Slope' of the relationship
geom_line(linewidth = 1.2, alpha = 0.8) +
# Add points for each quintile
geom_point(size = 4, fill = "white", shape = 21, stroke = 1.5) +
# Add labels at the end of each line
geom_text(
data = dt_plot[Level == "Richest"],
aes(label = `Countries and areas`),
hjust = -0.2, family = "Candara", fontface = "bold", size = 4
) +
scale_color_manual(values = cols) +
scale_y_continuous(labels = function(x) paste0(x, "%"), limits = c(0, 100)) +
scale_x_discrete(expand = expansion(mult = c(0.1, 0.4))) +
labs(
title = "The Wealth-Health Relationship",
subtitle = "How child care-seeking rates improve as households move from **Poorest** to **Richest**.",
x = "Wealth Quintile",
y = "% Children Receiving Care",
caption = "30DayChartChallenge 2026: <b> Day 17 (Relationships)</b> | Source: <b>UNICEF</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
plot.background = element_rect(fill = "#e4e4e3", color = NA),
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_line(linewidth = 0.3, color = "grey85"),
plot.title = element_markdown(size = 22, face = "bold", margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 13, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, hjust = 1, color = "grey40"),
axis.text = element_text(size = 11, face = "bold", color = "grey20"),
axis.title = element_text(size = 10, face = "bold", color = "grey40"),
plot.margin = margin(20, 20, 20, 20)
)
