# Load necessary libraries
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
library(gganimate) # For the animation
library(transformr) # Helps gganimate interpolate smooth lines
# 1. Load Data
mutant_df <- fread("https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2024/2024-03-19/mutant_moneyball.csv")
# 2. Clean and Melt the Data
# Select only the character name and their appearances per decade
cols_to_keep <- c("Member", "TotalIssues60s", "TotalIssues70s", "TotalIssues80s", "TotalIssues90s")
dt <- mutant_df[, ..cols_to_keep]
# Melt from "wide" to "long" format so gganimate can read it
dt_long <- melt(dt, id.vars = "Member", variable.name = "Decade", value.name = "Issues")
# Convert the column names into actual numeric years for smooth animation
dt_long[, Year := fcase(
Decade == "TotalIssues60s", 1960,
Decade == "TotalIssues70s", 1970,
Decade == "TotalIssues80s", 1980,
Decade == "TotalIssues90s", 1990
)]
# 3. Create the "Highlight" Categories
dt_long[, Status := fcase(
Member == "logan", "Wolverine (The Breakout)",
Member == "scottSummers", "Cyclops (The Anchor)",
Member == "warrenWorthington", "Angel (The Fading Star)",
default = "Other Mutants"
)]
# Order the data so the highlighted lines draw ON TOP of the grey lines
dt_long[, Status := factor(Status, levels = c("Other Mutants", "Angel (The Fading Star)", "Cyclops (The Anchor)", "Wolverine (The Breakout)"))]
setorder(dt_long, Status, Year)
# 4. Plotting
# We will use your favorite "Editorial Print" light theme!
bg_light  <- "#f7f7f9"
text_main <- "#1a1a1c"
text_sub  <- "#5e5e66"
# Define colors for our specific characters
hero_colors <- c(
"Other Mutants" = "#d1d1d6",             # Light ghost grey
"Angel (The Fading Star)" = "#7a7a85",   # Darker grey
"Cyclops (The Anchor)" = "#1d4ed8",      # Classic X-Men Blue
"Wolverine (The Breakout)" = "#d92525"   # Bold Red
)
gr <- ggplot(dt_long, aes(x = Year, y = Issues, group = Member, color = Status, size = Status)) +
# The Lines
geom_line(alpha = 0.8) +
# The Points (dots at each decade)
geom_point() +
# Map the colors and sizes manually based on our highlights
scale_color_manual(values = hero_colors) +
scale_size_manual(values = c("Other Mutants" = 0.4, "Angel (The Fading Star)" = 1.2, "Cyclops (The Anchor)" = 1.5, "Wolverine (The Breakout)" = 1.8)) +
# Clean up the axes
scale_x_continuous(breaks = c(1960, 1970, 1980, 1990), labels = c("1960s", "1970s", "1980s", "1990s")) +
labs(
title = "The Mutant Stock Market",
subtitle = "Tracking X-Men comic appearances across four decades.<br>While the original 60s roster seemed safe, narrative fates are highly <span style='color:#7a7a85'><b>uncertain</b></span>.<br><span style='color:#d92525'><b>Wolverine</b></span> exploded from obscurity to dominate the franchise, while founders faded away.",
caption = "30DayChartChallenge 2026: <b> Day 27 (Uncertainties) </b> | Prompt: <b>Animation</b> | Source: <b>Mutant Moneyball</b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "",
y = "Comic Book Appearances per Decade"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none", # Legend hidden, rely on colored text and visual hierarchy
plot.background = element_rect(fill = bg_light, color = NA),
panel.background = element_rect(fill = bg_light, color = NA),
panel.grid.major.y = element_line(color = "#e0e0e6", linewidth = 0.4, linetype = "dashed"),
panel.grid.major.x = element_line(color = "#e0e0e6", linewidth = 0.4),
panel.grid.minor = element_blank(),
axis.text = element_text(color = text_sub, size = 11, face = "bold"),
axis.title.y = element_text(color = text_main, size = 11, margin = margin(r = 15), face = "bold"),
plot.title = element_markdown(size = 22, face = "bold", hjust = 0, color = text_main, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 13, hjust = 0, color = text_sub, lineheight = 1.3, margin = margin(b = 25)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, color = "#8a8a94", hjust = 1),
plot.margin = margin(30, 30, 30, 30)
) +
# 5. THE ANIMATION MAGIC
# This single line tells the chart to draw the lines over time
transition_reveal(Year)
gr
# 6. Render and Save the Animation
# Note: Rendering animations takes a minute or two! Be patient while the progress bar runs in your console.
animate(
plot = gr,
fps = 20,          # Frames per second (20 is smooth but keeps file size down)
duration = 6,      # Total seconds the animation lasts
end_pause = 30,    # Pause on the final completed frame for 1.5 seconds
width = 9, height = 7, units = "in", res = 150, # Resolution
renderer = gifski_renderer("Day27_Animated_XMen.gif") # Saves as a GIF!
)
