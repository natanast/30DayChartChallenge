rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
library(ggridges) # For the mountain-range distributions
library(scales)   # For the log-scale axis formatting
# 1. Generate Biologically Accurate Data ------
set.seed(2026) # Seed ensures reproducibility
# Generating realistic genome sizes (in base pairs) using log-normal distributions
dt <- rbind(
data.table(Organism = "Viruses", Size_bp = 10^rnorm(800, mean = 4.8, sd = 0.6)),
data.table(Organism = "Bacteria", Size_bp = 10^rnorm(800, mean = 6.6, sd = 0.3)),
data.table(Organism = "Fungi", Size_bp = 10^rnorm(800, mean = 7.6, sd = 0.4)),
data.table(Organism = "Mammals", Size_bp = 10^rnorm(800, mean = 9.5, sd = 0.08)), # Very tight distribution!
data.table(Organism = "Plants", Size_bp = 10^rnorm(800, mean = 9.2, sd = 0.9))    # Massive variance!
)
# Order the factors so the plot reads logically from smallest (bottom) to largest (top)
dt[, Organism := factor(Organism, levels = c("Plants", "Mammals", "Fungi", "Bacteria", "Viruses"))]
# Let's use your beautiful muted, editorial color palette
col <- c(
"Viruses" = "#b24745",   # Terracotta
"Bacteria" = "#db9044",  # Orange/Gold
"Fungi" = "#7f9faa",     # Light Slate
"Mammals" = "#5a8192",   # Dark Slate Blue
"Plants" = "#6f6e9a"     # Muted Purple
)
# 2. Plot --------
gr <- ggplot(dt, aes(x = Size_bp, y = Organism, fill = Organism)) +
# Draw the multiscale ridgelines!
geom_density_ridges(
color = "white",       # White outlines separate the overlapping mountains
linewidth = 0.8,
alpha = 0.85,
scale = 1.8,           # Controls how much the mountains overlap
rel_min_height = 0.005 # Trims off the microscopic infinite tails
) +
scale_fill_manual(values = col) +
# THE MULTISCALE MAGIC:
# Log10 axis with custom biological labels
scale_x_log10(
breaks = c(1e4, 1e5, 1e6, 1e7, 1e8, 1e9, 1e10, 1e11),
labels = c("10 KB", "100 KB", "1 MB", "10 MB", "100 MB", "1 GB", "10 GB", "100 GB"),
expand = expansion(mult = c(0.01, 0.05))
) +
# Expand the Y-axis slightly so the top mountain doesn't get cut off
scale_y_discrete(expand = expansion(mult = c(0.05, 0.2))) +
labs(
title = "The Architecture of Life: Genome Sizes Across Kingdoms",
subtitle = "A <b>multiscale</b> distribution of DNA base pairs. Notice how strictly conserved mammalian<br>genomes are (~3 GB), compared to the massive evolutionary variance in plants.",
caption = "30DayChartChallenge 2026: <b> Day 7 (Distributions: Multiscale)</b> | Source: <b> Simulated Biological Data </b> | Graphic: <b>Natasa Anastasiadou</b>",
y = "",
x = "Genome Size (Log10 Base Pairs)"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none", # Ridgeline labels are on the Y-axis, so no legend needed!
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.text.y = element_text(size = 13, face = "bold", color = "black", vjust = 0),
axis.text.x = element_text(size = 10, face = "bold", color = "grey40"),
# Vertical gridlines help the reader measure the peaks
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey80", linetype = "dashed"),
panel.grid.minor.x = element_blank(),
panel.grid.major.y = element_blank(), # Remove horizontal lines for a cleaner sky
plot.title = element_markdown(size = 18, face = "bold", hjust = 0, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
# 1. Load data ------
# We use the curated 'msleep' dataset built right into ggplot2!
# Published in PNAS (Savage & West, 2007)
dt <- as.data.table(ggplot2::msleep)
# 2. Clean data ------
# Remove rows missing diet (vore) or body weight
dt <- dt[!is.na(vore) & !is.na(bodywt)]
# Rename the biological categories for publication
dt[, vore := fcase(
vore == "carni", "Carnivores",
vore == "herbi", "Herbivores",
vore == "insec", "Insectivores",
vore == "omni", "Omnivores"
)]
# Order factors from smallest median weight to largest
dt[, vore := factor(vore, levels = c("Insectivores", "Carnivores", "Omnivores", "Herbivores"))]
# Your editorial palette
col <- c(
"Insectivores" = "#7f9faa",
"Carnivores"   = "#b24745",
"Omnivores"    = "#db9044",
"Herbivores"   = "#5a8192"
)
# 3. Plot --------
gr <- ggplot(dt, aes(x = bodywt, y = vore, fill = vore)) +
# The Ridgeline plot with raw data points layered underneath!
geom_density_ridges(
jittered_points = TRUE,
position = position_points_jitter(width = 0.05, height = 0),
point_shape = 21,
point_size = 2.5,
point_color = "white",
point_fill = "grey20", # Makes the animal dots stand out against the colored mountains
alpha = 0.8,
color = "white",
scale = 1.2
) +
scale_fill_manual(values = col) +
# THE MULTISCALE MAGIC:
# Converting the raw kg numbers into readable biological scales
scale_x_log10(
breaks = c(0.01, 0.1, 1, 10, 100, 1000),
labels = c("10g", "100g", "1 kg", "10 kg", "100 kg", "1 Ton"),
expand = expansion(mult = c(0.05, 0.1))
) +
labs(
title = "The Multiscale Mass of Mammals",
subtitle = "A logarithmic distribution of mammalian body weights.<br>Notice how herbivores span from tiny rodents to African elephants (6 Tons).",
caption = "30DayChartChallenge 2026: <b> Day 7 (Distributions: Multiscale)</b> | Source: <b> Savage & West (2007) PNAS </b> | Graphic: <b>Natasa Anastasiadou</b>",
y = "",
x = "Body Weight (Logarithmic Scale)"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.text.y = element_text(size = 12, face = "bold", color = "black", vjust = 0),
axis.text.x = element_text(size = 11, face = "bold", color = "grey40"),
# Vertical dashed lines perfectly show the orders of magnitude (10g -> 100g -> 1kg)
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey80", linetype = "dashed"),
panel.grid.minor.x = element_blank(),
panel.grid.major.y = element_blank(),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
library(ggridges)
library(scales)
# 1. Load data ------
# TidyTuesday: Global Power Plant Database (June 2020)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-06-09/power_plants.csv"
dt <- fread(url)
# 2. Clean and Downsample data ------
# Select the major energy sources we want to compare
target_fuels <- c("Solar", "Wind", "Hydro", "Coal", "Nuclear")
dt_sub <- dt[primary_fuel %in% target_fuels & !is.na(capacity_mw)]
# PRO TIP: Stratified sampling!
# We take a random sample of 300 plants per category so the jittered dots look beautiful and don't overlap into a solid block.
set.seed(2026)
dt_plot <- dt_sub[, .SD[sample(.N, min(.N, 300))], by = primary_fuel]
# 1. Load data ------
# TidyTuesday: Global Power Plant Database (June 2020)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-06-09/power_plants.csv"
dt <- fread(url)
# 1. Load data ------
# TidyTuesday: Global Power Plant Database (June 2020)
# 1. Load data ------
# Updated the URL from 'master' to 'main'
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2020/2020-06-09/power_plants.csv"
dt <- fread(url)
# 1. Load data ------
# TidyTuesday: NASA Meteorite Landings (June 2019)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2019/2019-06-11/meteorites.csv"
dt <- fread(url)
# 2. Clean and classify data ------
# Remove missing masses and impossible 0g weights
dt <- dt[!is.na(mass) & mass > 0]
# Meteorites have hundreds of sub-classes. Let's group them into the 4 major astronomical categories!
dt[, broad_class := fcase(
grepl("Iron", class, ignore.case = TRUE), "Iron (Core fragments)",
grepl("Pallasite|Mesosiderite", class, ignore.case = TRUE), "Stony-Iron (Mantle fragments)",
grepl("Eucrite|Diogenite|Howardite|Achondrite|Lunar|Martian", class, ignore.case = TRUE), "Achondrite (Crust fragments)",
default = "Chondrite (Primitive solar dust)"
)]
# PRO TIP: Stratified sampling!
# We take a random sample of 400 meteorites per category so the jittered dots look beautiful and don't turn into a solid block of ink.
set.seed(2026)
dt_plot <- dt[, .SD[sample(.N, min(.N, 400))], by = broad_class]
# Order them logically by density
dt_plot[, broad_class := factor(broad_class, levels = c(
"Chondrite (Primitive solar dust)",
"Achondrite (Crust fragments)",
"Stony-Iron (Mantle fragments)",
"Iron (Core fragments)"
))]
# Your editorial palette
col <- c(
"Chondrite (Primitive solar dust)" = "#7f9faa", # Slate
"Achondrite (Crust fragments)"     = "#6f6e9a", # Muted Purple
"Stony-Iron (Mantle fragments)"    = "#db9044", # Terracotta/Orange
"Iron (Core fragments)"            = "#b24745"  # Deep Red/Iron
)
# 3. Plot --------
gr <- ggplot(dt_plot, aes(x = mass, y = broad_class, fill = broad_class)) +
geom_density_ridges(
jittered_points = TRUE,
position = position_points_jitter(width = 0.05, height = 0),
point_shape = 21,
point_size = 2,
point_color = "white",
point_fill = "grey20",
alpha = 0.8,
color = "white",
scale = 1.2
) +
scale_fill_manual(values = col) +
# THE MULTISCALE MAGIC:
# Converting raw grams into highly readable biological/physical scales
scale_x_log10(
breaks = c(1, 10, 100, 1000, 10000, 100000, 1000000, 10000000),
labels = c("1g", "10g", "100g", "1 kg", "10 kg", "100 kg", "1 Tonne", "10 Tonnes"),
expand = expansion(mult = c(0.05, 0.1))
) +
labs(
title = "The Multiscale Mass of Meteorites",
subtitle = "A logarithmic distribution of meteorite masses fallen to Earth.<br>Notice how dense <b>Iron</b> meteorites survive atmospheric entry at significantly larger scales.",
caption = "30DayChartChallenge 2026: <b> Day 7 (Distributions)</b> | Source: <b> NASA / TidyTuesday </b> | Graphic: <b>Natasa Anastasiadou</b>",
y = "",
x = "Meteorite Mass (Logarithmic Scale)"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.text.y = element_text(size = 12, face = "bold", color = "black", vjust = 0),
axis.text.x = element_text(size = 11, face = "bold", color = "grey40"),
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey85", linetype = "dashed"),
panel.grid.minor.x = element_blank(),
panel.grid.major.y = element_blank(),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
