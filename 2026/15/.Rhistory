# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
# 1. Load data ------
energy_types <- fread('https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-08-04/energy_types.csv')
# 2. Clean & Filter for Trade ------
# We want to compare Imports and Exports for the year 2018
trade_dt <- energy_types[type %in% c("Imports", "Exports")]
trade_dt <- trade_dt[, .(value = sum(`2018`)), by = .(country_name, type)]
# Filter for the top 15 trading countries to keep it "Quiet"
top_countries <- trade_dt[, .(total = sum(value)), by = country_name][order(-total)][1:15, country_name]
trade_plot <- trade_dt[country_name %in% top_countries]
energy_types
rm(list = ls())
gc()
# 1. Load data ------
energy_types <- 'https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-08-04/energy_types.csv' |>
fread()
energy_types
# 1. Load data ------
energy_types <- 'https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-08-04/energy_types.csv' |>
fread(header = FALSE)
energy_types
# 1. Load data ------
energy_types <- 'https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-08-04/energy_types.csv' |>
fread()
energy_types
# Promote the first row to column names
setnames(energy_types, as.character(energy_types[1, ]))
energy_types <- energy_types[-1] # Remove the now-redundant first row
# Convert the year columns to numeric (they were likely characters because of the header row)
cols_to_fix <- c("2016", "2017", "2018")
energy_types[, (cols_to_fix) := lapply(.SD, as.numeric), .SDcols = cols_to_fix]
# Pivot wider
trade_wide <- dcast(trade_dt, country_name ~ type, value.var = "value")
# To keep the plot "Quiet," let's filter for the top 15 countries by trade volume
trade_wide[, total_trade := Imports + Exports]
trade_wide <- trade_wide[order(-total_trade)][1:15]
# 1. Load data ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-08-04/energy_types.csv"
energy_raw <- fread(url)
# 2. Clean data headers and types ------
# Promote the first row to column names and remove it
setnames(energy_raw, as.character(energy_raw[1, ]))
energy_dt <- energy_raw[-1]
# Convert year columns to numeric
year_cols <- c("2016", "2017", "2018")
energy_dt[, (year_cols) := lapply(.SD, as.numeric), .SDcols = year_cols]
# 3. Transform for Trade Relationship (2018) ------
# Filter for Imports and Exports only
trade_dt <- energy_dt[type %in% c("Imports", "Exports")]
# Summarize by country (some countries have multiple entries for levels)
trade_sum <- trade_dt[, .(value = sum(`2018`, na.rm = TRUE)), by = .(country_name, type)]
# Pivot wider for the dumbbell structure (segment x to xend)
trade_wide <- dcast(trade_sum, country_name ~ type, value.var = "value")
# Keep the top 15 trading countries to keep the chart "Quiet"
trade_wide[, total_volume := Imports + Exports]
trade_plot <- trade_wide[order(-total_volume)][1:15]
# Clear environment
rm(list = ls())
gc()
# Load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(scales)
# 1. Load data (Using 'country_totals.csv' for trade data) ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-08-04/country_totals.csv"
dt_raw <- fread(url)
# 2. Fix Headers & Types ------
# If fread didn't catch the headers (common with this file), we fix it manually
if ("V1" %in% names(dt_raw)) {
setnames(dt_raw, as.character(dt_raw[1, ]))
dt_raw <- dt_raw[-1]
}
# Rename the 2018 column to be safe (handles "2018" or "2018.000")
setnames(dt_raw, 7, "value_2018")
dt_raw[, value_2018 := as.numeric(value_2018)]
# 3. Transform for Trade Relationship ------
# Now we can find "Imports" and "Exports" successfully!
trade_dt <- dt_raw[type %in% c("Imports", "Exports")]
# Pivot wider so we have an 'Imports' column and an 'Exports' column
trade_wide <- dcast(trade_dt, country_name ~ type, value.var = "value_2018")
# Calculate total volume for sorting and filter for the top 15
trade_wide[, total_volume := Imports + Exports]
trade_plot <- trade_wide[order(-total_volume)][1:15]
# 4. Palette -------
cols <- c("Exports" = "#b25c56", "Imports" = "#4a6b7c")
# 5. Plot --------
gr_trade <- ggplot(trade_plot) +
# Connecting line (The "Relationship")
geom_segment(
aes(x = Exports, xend = Imports,
y = reorder(country_name, Imports), yend = country_name),
color = "grey80", linewidth = 1.2
) +
# Export dot (Brick)
geom_point(
aes(x = Exports, y = country_name),
color = "#b25c56", size = 4
) +
# Import dot (Slate)
geom_point(
aes(x = Imports, y = country_name),
color = "#4a6b7c", size = 4
) +
scale_x_continuous(labels = comma_format()) +
labs(
title = "The European Energy Exchange",
subtitle = "Comparing <span style='color:#4a6b7c;'>**Imports**</span> and <span style='color:#b25c56;'>**Exports**</span> of energy (GWh, 2018).<br>The line represents the trade balance: the longer the gap, the greater the dependency.",
caption = "30DayChartChallenge 2026: <b> Day 14 (Trade) </b> | Source: <b> Eurostat </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "Energy Amount (GWh)",
y = NULL
) +
theme_minimal(base_family = "Candara") +
theme(
panel.grid.major.x = element_line(color = "white", linewidth = 0.5),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
plot.background = element_rect(fill = "#f2f2f2", color = NA),
panel.background = element_rect(fill = "#f2f2f2", color = NA),
# Typography
axis.text = element_text(size = 10, face = "bold", color = "grey40"),
axis.title.x = element_text(size = 10, face = "bold", color = "grey50", margin = margin(t = 15)),
plot.title = element_text(size = 22, face = "bold", color = "black", hjust = 0),
plot.subtitle = element_markdown(size = 12, color = "grey40", margin = margin(b = 20), lineheight = 1.3),
plot.caption = element_markdown(size = 8, color = "grey50", margin = margin(t = 20)),
plot.margin = margin(30, 30, 30, 30)
)
print(gr_trade)
# 6. Save -------
ggsave("Day14_Energy_Trade.png", plot = gr_trade, width = 10, height = 8, dpi = 600)
ggsave(
plot = gr, filename = "Rplot.png",
width = 10, height = 10, units = "in", dpi = 600
)
print(gr_trade)
rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
# 1. Load data ------
url <- 'https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-02-18/food_consumption.csv'
dt <- fread(url)
# 2. Clean & Filter ------
# Let's focus on European countries and key "Trade" commodities
target_countries <- c("France", "Italy", "Greece", "Spain", "Germany",
"United Kingdom", "Belgium", "Austria", "Portugal")
target_foods <- c("Wine", "Beer", "Beef", "Fish", "Wheat")
dt_plot <- dt[country %in% target_countries & food_category %in% target_foods]
# 3. Plot --------
gr <- ggplot(dt_plot, aes(x = food_category, y = country, fill = consumption)) +
# The Heatmap Tiles
geom_tile(color = "white", linewidth = 0.5) +
# Text labels inside tiles for that "pro" editorial look
geom_text(aes(label = round(consumption, 0)),
family = "Candara", size = 3.5,
color = ifelse(dt_plot$consumption > 25, "white", "grey20")) +
# Wine-inspired color palette: Cream to Deep Burgundy
scale_fill_gradient(low = "#fdf2f2", high = "#800020", name = "kg/person") +
labs(
title = "The European Trade Profile",
subtitle = "Visualizing the relationship between nations and their key trade-dependent commodities.<br>Intensity represents annual consumption per person (kg).",
caption = "30DayChartChallenge 2026: <b> Day 14 (Trade) </b> | Source: <b> nu3 </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = NULL,
y = NULL
) +
theme_minimal(base_family = "Candara") +
theme(
# The signature "Natasa" clean background
plot.background = element_rect(fill = "#f2f2f2", color = NA),
panel.grid = element_blank(),
# Axis styling
axis.text.x = element_text(size = 11, face = "bold", color = "grey30"),
axis.text.y = element_text(size = 11, face = "bold", color = "grey30"),
# Legend styling
legend.position = "right",
legend.title = element_text(size = 9, face = "bold"),
# Title and Subtitle
plot.title = element_text(size = 22, face = "bold", color = "black", margin = margin(b = 5)),
plot.subtitle = element_markdown(size = 11, color = "grey40", margin = margin(b = 20)),
plot.caption = element_markdown(size = 8, color = "grey60", margin = margin(t = 20)),
plot.margin = margin(30, 30, 30, 30)
)
gr
rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(tidytuesdayR)
# load data ------
tuesdata <- tt_load("2022-03-08")
erasmus_raw <- as.data.table(tuesdata$erasmus)
library(data.table)
library(tidytuesdayR)
# load data ------
erasmus_raw <- fread('https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2022/2022-03-08/erasmus.csv')
# clean data ------
# Focus on total participants between countries
df <- erasmus_raw[, .(n = sum(participants)), by = .(sending_country_code, receiving_country_code)]
# To keep the heatmap readable, we'll take the top 22 "trading" countries by volume
top_countries <- df[, .(total = sum(n)), by = sending_country_code][order(-total)][1:22, sending_country_code]
df_plot <- df[sending_country_code %in% top_countries & receiving_country_code %in% top_countries]
# Reorder factors so the heatmap has a logical flow (by volume)
df_plot[, sending_country_code := fct_reorder(sending_country_code, n, sum)]
df_plot[, receiving_country_code := fct_reorder(receiving_country_code, n, sum)]
# load libraries -------
library(data.table)
library(tidyverse) # for fct_reorder
library(stringr)
library(ggplot2)
library(ggtext)
library(extrafont)
library(colorspace)
library(viridis)
# load data ------
erasmus_raw <- fread('https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2022/2022-03-08/erasmus.csv')
# clean data ------
# Focus on total participants between countries
df <- erasmus_raw[, .(n = sum(participants)), by = .(sending_country_code, receiving_country_code)]
# To keep the heatmap readable, we'll take the top 22 "trading" countries by volume
top_countries <- df[, .(total = sum(n)), by = sending_country_code][order(-total)][1:22, sending_country_code]
df_plot <- df[sending_country_code %in% top_countries & receiving_country_code %in% top_countries]
# Reorder factors so the heatmap has a logical flow (by volume)
df_plot[, sending_country_code := fct_reorder(sending_country_code, n, sum)]
df_plot[, receiving_country_code := fct_reorder(receiving_country_code, n, sum)]
# Define a base color for the scale to use with colorspace if needed
base_col <- "#b24745"
gr <- ggplot(df_plot, aes(x = sending_country_code, y = receiving_country_code)) +
# Heatmap tiles with a subtle border
geom_tile(aes(fill = n), color = "grey95", linewidth = 0.5) +
coord_equal() +
# Color scale using Viridis (Magma) - works beautifully for "intensity"
scale_fill_viridis_c(
option = "magma",
trans = "log10", # Log scale helps visualize smaller relationships
name = "Participants",
labels = scales::comma_format(),
begin = 0.1, end = 0.9
) +
labs(
title = "The Global **Trade** of Knowledge",
subtitle = "<b>Relationships</b> between Erasmus+ sending and receiving countries. <br>
The color intensity represents the <b>total number of participants</b> (log10 scale).",
caption = "30DayChartChallenge 2026: <b> Day 14 | Relationships (Trade)</b>
| Source: <b>TidyTuesday (Erasmus Student Mobility)</b>
| Graphic: <b>Natasa Anastasiadou</b>",
x = "Sending Country",
y = "Receiving Country"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "right",
legend.title = element_text(size = 9, face = "bold"),
legend.key.height = unit(1.2, "cm"),
# Grid and axis setup
panel.grid = element_blank(),
axis.title = element_text(size = 10, face = "bold", color = "grey30"),
axis.text.x = element_text(angle = 45, hjust = 1, size = 9),
axis.text.y = element_text(size = 9),
# Natasa's Signature Styling
plot.title = element_markdown(size = 18, face = "bold", hjust = 0, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 25), size = 8, hjust = 1, color = "grey40"),
plot.background = element_rect(fill = "grey95", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
# Display plot
gr
