width = 9, height = 8, units = "in", dpi = 600
)
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
library(colorspace)
library(ggdag)     # For generating DAG structures (install if needed)
install.packages("ggdag")
library(ggdag)     # For generating DAG structures (install if needed)
# create causal data ------
# We define the causal relationships using dagify()
# Geography -> Species
# Species & Sex -> Physical Traits
dag_model <- dagify(
Species ~ Island,
Body_Mass ~ Species + Sex,
Flipper_Length ~ Species + Sex,
labels = c(
"Island" = "Island Location",
"Species" = "Penguin Species",
"Sex" = "Biological Sex",
"Body_Mass" = "Body Mass",
"Flipper_Length" = "Flipper Length"
)
)
# Convert the DAG to a tidy format, then to a data.table
dag_tidy <- tidy_dagitty(dag_model)
df_dag <- as.data.table(dag_tidy$data)
# Categorize the nodes so we can color them beautifully
df_dag[!is.na(name), category := fcase(
name == "Island", "Geography",
name %in% c("Species", "Sex"), "Demographics",
name %in% c("Body_Mass", "Flipper_Length"), "Physical Traits"
)]
# Because ggdag repeats node rows for every edge connection,
# we need a unique data.table for the labels to prevent text from rendering on top of itself
df_nodes <- unique(df_dag[!is.na(name), .(name, x, y, label, category)])
# Define your signature color palette
col <- c("Geography" = "#81A88D", "Demographics" = "#678e9f", "Physical Traits" = "#b24745")
# plot --------
gr <- ggplot(df_dag, aes(x = x, y = y, xend = xend, yend = yend)) +
# 1. Draw the causal arrows (edges) connecting the concepts
geom_dag_edges(
edge_color = "grey60",
edge_width = 0.75,
arrow_directed = grid::arrow(length = grid::unit(10, "pt"), type = "closed")
) +
# 2. Draw the nodes as rounded text labels (this looks incredibly clean!)
geom_label(
data = df_nodes,
aes(x = x, y = y, label = label, fill = category),
inherit.aes = FALSE, # We don't need xend/yend here
color = "white",
family = "Candara",
fontface = "bold",
size = 4.5,
label.padding = unit(0.7, "lines"),
label.r = unit(0.4, "lines"),
label.size = 0 # Removes the default border around the label for a modern look
) +
scale_fill_manual(values = col) +
# theme_void removes all coordinate axes, grids, and background panels
theme_void(base_family = "Candara") +
labs(
title = "The Causal Architecture of Palmer Penguins",
subtitle = "A Directed Acyclic Graph (DAG) mapping the **causal pathways**<br>between a penguin's geography, demographics, and physical traits.",
caption = "30DayChartChallenge 2026 | Day 16: Causation (Relationships) <br> Source: <b>palmerpenguins</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme(
legend.position = "bottom",
legend.title = element_blank(),
legend.text = element_text(size = 10, family = "Candara", color = "grey30", face = "bold"),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, margin = margin(b = 5, t = 10)),
plot.subtitle = element_markdown(size = 12, hjust = 0.5, color = "grey30", margin = margin(b = 30)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, hjust = 1, color = "grey40"),
plot.margin = margin(30, 30, 30, 30),
plot.background = element_rect(fill = "grey93", color = NA)
)
gr
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
library(colorspace)
library(ggalluvial)
# load data ------
rent <- fread('https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2022/2022-07-05/rent.csv')
# clean data ------
# We want to see how apartment features "cause" the final price tier in SF
df <- rent[city == "san francisco" & beds %in% c(1, 2, 3) & baths %in% c(1, 2) & !is.na(price)]
df[, Bed_Cat := paste0(beds, " Bed(s)")]
df[, Bath_Cat := paste0(baths, " Bath(s)")]
# Define Price Tiers based on quantiles to ensure even distribution
tertiles <- quantile(df$price, probs = c(0.33, 0.66), na.rm = TRUE)
df[, Price_Tier := fcase(
price <= tertiles[1], "Low Tier",
price > tertiles[1] & price <= tertiles[2], "Mid Tier",
price > tertiles[2], "High Tier"
)]
# Aggregate the flows
df_agg <- df[, .(N = .N), by = .(Bed_Cat, Bath_Cat, Price_Tier)]
# Reorder factors for visual logic (highest to lowest)
df_agg$Bed_Cat <- factor(df_agg$Bed_Cat, levels = c("3 Bed(s)", "2 Bed(s)", "1 Bed(s)"))
df_agg$Bath_Cat <- factor(df_agg$Bath_Cat, levels = c("2 Bath(s)", "1 Bath(s)"))
df_agg$Price_Tier <- factor(df_agg$Price_Tier, levels = c("High Tier", "Mid Tier", "Low Tier"))
# plot --------
gr <- ggplot(df_agg,
aes(y = N, axis1 = Bed_Cat, axis2 = Bath_Cat, axis3 = Price_Tier)) +
# The flowing causal ribbons
geom_alluvium(aes(fill = Price_Tier), width = 1/6, alpha = 0.85, color = "white", linewidth = 0.4) +
# The vertical blocks (nodes)
geom_stratum(width = 1/4, fill = "grey85", color = "grey20", linewidth = 0.3) +
# Labels inside the blocks
geom_text(stat = "stratum", aes(label = after_stat(stratum)),
family = "Candara", size = 3.5, fontface = "bold", color = "grey10") +
# Label the axes
scale_x_discrete(limits = c("Bedrooms", "Bathrooms", "Rent Price"), expand = c(0.1, 0.1)) +
# Apply your specific color palette
scale_fill_manual(values = c("High Tier" = "#b24745", "Mid Tier" = "#81A88D", "Low Tier" = "#678e9f")) +
theme_minimal(base_family = "Candara") +
labs(
title = "The Causal Pathway of Rent Prices",
subtitle = "Tracing how the physical characteristics of an apartment **cause** its final price tier.<br>Data reflects 1-3 bedroom rentals in San Francisco.",
caption = "30DayChartChallenge 2026 | Day 16: Causation (Relationships) <br> Source: <b>TidyTuesday (SF Rents)</b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme(
legend.position = "none", # The labels and colors explain themselves within the plot
panel.grid = element_blank(),
axis.text.y = element_blank(),
axis.title = element_blank(),
axis.text.x = element_text(size = 11, face = "bold", color = "grey30"),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, margin = margin(b = 5, t = 10)),
plot.subtitle = element_markdown(size = 12, hjust = 0.5, color = "grey30", margin = margin(b = 30)),
plot.caption = element_markdown(margin = margin(t = 30), size = 8, hjust = 1, color = "grey40"),
plot.margin = margin(30, 30, 30, 30),
plot.background = element_rect(fill = "grey95", color = NA)
)
gr
# load libraries -------
library(data.table)
library(ggplot2)
library(stringr)
library(ggtext)
library(extrafont)
library(colorspace)
library(shadowtext)
library(scales)
# load data ------
# We use a simulated dataset representing a project timeline,
# to cleanly show the additive/subtractive steps of a causal waterfall.
df <- data.table(
cause = c("Initial Estimate", "Scope Creep", "Code Refactoring", "Lost Developer", "Faster Testing", "Final Delivery"),
days_change = c(45, 14, 8, 12, -7, NA) # NA for the final total column
)
# 1. Calculate the cumulative total at each step
df[, current_total := cumsum(fcoalesce(days_change, 0))]
# 2. Calculate ymin (where the bar starts) and ymax (where it ends)
df[, `:=`(
ymin = shift(current_total, n = 1, fill = 0),
ymax = current_total
)]
# 3. The Final Delivery bar should start at 0 and go up to the final total
final_val <- df[.N, ymax]
df[.N, `:=`(ymin = 0, days_change = final_val)]
# 4. Create a category for our color palette
df[, type := fcase(
cause == "Initial Estimate", "Baseline",
cause == "Final Delivery", "Total Delay",
days_change < 0, "Time Saved (Mitigation)",
days_change > 0, "Delay Driver (Cause)"
)]
# 5. Lock in the factor order so the X-axis stays sequential
df[, cause := factor(cause, levels = cause)]
# Define color palette matching your aesthetic
col <- c(
"Baseline" = "#678e9f",                 # Blue
"Delay Driver (Cause)" = "#b24745",     # Red
"Time Saved (Mitigation)" = "#81A88D",  # Green
"Total Delay" = "grey20"                # Dark Grey
)
# plot --------
gr = ggplot(df, aes(fill = type)) +
# 1. The connecting dashed lines between steps (draw these first so they sit behind bars)
geom_segment(
aes(x = as.numeric(cause) - 0.45, xend = as.numeric(cause) + 0.45,
y = ymax, yend = ymax),
color = "grey50", linetype = "dashed", linewidth = 0.4
) +
# 2. The floating vertical bars
geom_rect(
aes(xmin = as.numeric(cause) - 0.4, xmax = as.numeric(cause) + 0.4,
ymin = ymin, ymax = ymax),
color = "grey10", linewidth = 0.3
) +
# 3. The text labels showing the exact causal impact
geom_shadowtext(
aes(x = cause,
y = pmax(ymin, ymax) + 2, # Always place slightly above the highest point of the bar
label = ifelse(cause %in% c("Initial Estimate", "Final Delivery"),
paste0(days_change, " Days"),
paste0(ifelse(days_change > 0, "+", ""), days_change))),
color = "black", family = "Candara", bg.color = "grey93", bg.r = 0.1, size = 3.5, fontface = "bold"
) +
scale_fill_manual(values = col) +
# Expand the Y axis slightly at the top so the highest label doesn't get cut off
scale_y_continuous(limits = c(0, max(df$ymax) + 5), expand = c(0, 0)) +
theme_minimal() +
labs(
title = "The Causal Chain of **Project Slippage**",
subtitle = "Analyzing the specific factors that **caused** a software project to miss its deadline.<br>Showing the step-by-step impact of delays and mitigations.",
caption = "30DayChartChallenge 2026 | Day 16: Causation (Relationships) <br> Source: <b>Project Tracker (Simulated)</b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "Causal Factor",
y = "Total Timeline (Days)"
) +
theme(
legend.position = "top",
legend.title = element_blank(),
legend.text = element_text(size = 9, family = "Candara", color = "grey30", face = "bold"),
legend.key.size = unit(0.8, "lines"),
axis.title.x = element_text(size = 9, family = "Candara", face = "bold", margin = margin(t = 15)),
axis.title.y = element_text(size = 9, family = "Candara", face = "bold", margin = margin(r = 10)),
# X-axis text bolded for readability
axis.text.x = element_text(size = 9, family = "Candara", face = "bold", color = "grey20"),
axis.text.y = element_text(size = 8, family = "Candara"),
# Remove vertical grid lines for a cleaner waterfall look
panel.grid.major.x = element_blank(),
panel.grid.minor = element_blank(),
panel.grid.major.y = element_line(color = "grey85", linewidth = 0.4),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, family = "Candara", margin = margin(b = 5, t = 10)),
plot.subtitle = element_markdown(size = 11, hjust = 0.5, family = "Candara", color = "grey30", margin = margin(b = 20)),
plot.caption = element_markdown(margin = margin(t = 25), size = 8, family = "Candara", hjust = 1, color = "grey40"),
plot.margin = margin(20, 20, 20, 20),
plot.background = element_rect(fill = "grey93", color = NA)
)
gr
# load data ------
df <- data.table(
cause = c("Initial Estimate", "Scope Creep", "Code Refactoring", "Lost Developer", "Faster Testing", "Final Delivery"),
days_change = c(45, 14, 8, 12, -7, NA)
)
# clean data & calculate waterfall logic ------
df[, current_total := cumsum(fcoalesce(days_change, 0))]
df[, `:=`(
ymin = shift(current_total, n = 1, fill = 0),
ymax = current_total
)]
final_val <- df[.N, ymax]
df[.N, `:=`(ymin = 0, days_change = final_val)]
df[, type := fcase(
cause == "Initial Estimate", "Baseline",
cause == "Final Delivery", "Total Delay",
days_change < 0, "Time Saved (Mitigation)",
days_change > 0, "Delay Driver (Cause)"
)]
df[, cause := factor(cause, levels = cause)]
# Define color palette
col <- c(
"Baseline" = "#678e9f",
"Delay Driver (Cause)" = "#b24745",
"Time Saved (Mitigation)" = "#81A88D",
"Total Delay" = "grey20"
)
# plot --------
gr = ggplot(df, aes(fill = type)) +
# 1. Connecting dashed lines
geom_segment(
aes(x = as.numeric(cause) - 0.45, xend = as.numeric(cause) + 0.45,
y = ymax, yend = ymax),
color = "grey50", linetype = "dashed", linewidth = 0.4
) +
# 2. Floating vertical bars (Numeric X)
geom_rect(
aes(xmin = as.numeric(cause) - 0.4, xmax = as.numeric(cause) + 0.4,
ymin = ymin, ymax = ymax),
color = "grey10", linewidth = 0.3
) +
# 3. Text labels (Fix applied here: x = as.numeric(cause))
geom_shadowtext(
aes(x = as.numeric(cause),
y = pmax(ymin, ymax) + 2,
label = ifelse(cause %in% c("Initial Estimate", "Final Delivery"),
paste0(days_change, " Days"),
paste0(ifelse(days_change > 0, "+", ""), days_change))),
color = "black", family = "Candara", bg.color = "grey93", bg.r = 0.1, size = 3.5, fontface = "bold"
) +
scale_fill_manual(values = col) +
# Expand Y axis
scale_y_continuous(limits = c(0, max(df$ymax) + 5), expand = c(0, 0)) +
# Fix applied here: Map the text levels back onto the numeric axis, wrapping text so it looks clean
scale_x_continuous(
breaks = 1:length(levels(df$cause)),
labels = str_wrap(levels(df$cause), width = 12)
) +
theme_minimal() +
labs(
title = "The Causal Chain of **Project Slippage**",
subtitle = "Analyzing the specific factors that **caused** a software project to miss its deadline.<br>Showing the step-by-step impact of delays and mitigations.",
caption = "30DayChartChallenge 2026 | Day 16: Causation (Relationships) <br> Source: <b>Project Tracker (Simulated)</b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "Causal Factor",
y = "Total Timeline (Days)"
) +
theme(
legend.position = "top",
legend.title = element_blank(),
legend.text = element_text(size = 9, family = "Candara", color = "grey30", face = "bold"),
legend.key.size = unit(0.8, "lines"),
axis.title.x = element_text(size = 9, family = "Candara", face = "bold", margin = margin(t = 15)),
axis.title.y = element_text(size = 9, family = "Candara", face = "bold", margin = margin(r = 10)),
axis.text.x = element_text(size = 9, family = "Candara", face = "bold", color = "grey20"),
axis.text.y = element_text(size = 8, family = "Candara"),
panel.grid.major.x = element_blank(),
panel.grid.minor = element_blank(),
panel.grid.major.y = element_line(color = "grey85", linewidth = 0.4),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, family = "Candara", margin = margin(b = 5, t = 10)),
plot.subtitle = element_markdown(size = 11, hjust = 0.5, family = "Candara", color = "grey30", margin = margin(b = 20)),
plot.caption = element_markdown(margin = margin(t = 25), size = 8, family = "Candara", hjust = 1, color = "grey40"),
plot.margin = margin(20, 20, 20, 20),
plot.background = element_rect(fill = "grey93", color = NA)
