# 1. Load data & ensure countrycode is ready ------
if(!require(countrycode)) install.packages("countrycode")
library(countrycode)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2023/2023-06-06/owid-energy.csv"
dt <- fread(url)
# 2. Clean and Filter ------
# Filter for 2020 and true countries
dt_clean <- dt[year == 2020 & nchar(iso_code) == 3]
# Calculate GDP per Capita
dt_clean[, gdp_per_capita := gdp / population]
# Drop missing values
dt_clean <- dt_clean[!is.na(gdp_per_capita) & !is.na(renewables_share_energy) & !is.na(population)]
# Force the creation of the continent column
dt_clean$continent <- countrycode(sourcevar = dt_clean$iso_code, origin = "iso3c", destination = "continent")
# Now we can safely remove any unmatched territories
dt_clean <- dt_clean[!is.na(continent)]
# Sort by population descending so large bubbles go to the back!
dt_clean <- dt_clean[order(-population)]
# 3. Create the Palette (Matching your reference image) -------
cols <- c(
"Africa"   = "#b25c56",  # Dark Brick Red
"Americas" = "#e8998f",  # Soft Coral/Pink
"Asia"     = "#fcd4be",  # Pale Peach
"Europe"   = "#85aebc",  # Soft Slate Blue
"Oceania"  = "#4a6b7c"   # Dark Slate Blue
)
# 4. Plot --------
gr <- ggplot(dt_clean, aes(x = gdp_per_capita, y = renewables_share_energy, color = continent, size = population)) +
# Draw the bubbles with transparency
geom_point(alpha = 0.85, stroke = 0) +
# Label key countries to tell the story (Extremes and massive populations)
geom_text_repel(data = dt_clean[country %in% c("Norway", "Iceland", "United States", "China", "India", "Brazil", "Qatar", "Greece")],
aes(label = country),
family = "Candara", size = 3.5, color = "black", fontface = "bold",
box.padding = 0.8, point.padding = 0.3,
min.segment.length = 0, segment.color = "grey50", show.legend = FALSE) +
# Map the exact colors
scale_color_manual(values = cols, name = "Continent") +
# Log the X-axis for GDP, and scale the bubbles smoothly
scale_x_log10(labels = scales::dollar_format()) +
scale_size_continuous(range = c(2, 20), guide = "none") + # Hide population legend to keep it clean
labs(
title = "Wealth and the green energy transition",
subtitle = "Correlating GDP per capita with the share of primary energy derived from renewables.<br>Each bubble represents a country, sized by its total population.",
caption = "30DayChartChallenge 2026: <b> Day 15 (Correlation) </b> | Source: <b> Our World in Data </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "GDP per Capita (Log Scale)",
y = "Renewable Energy Share (%)"
) +
theme_minimal(base_family = "Candara") +
theme(
# The reference image uses dashed gridlines on a light grey background
panel.grid.major = element_line(color = "grey80", linetype = "dashed", linewidth = 0.4),
panel.grid.minor = element_blank(),
plot.background = element_rect(fill = "#f2f2f2", color = NA),
panel.background = element_rect(fill = "#f2f2f2", color = NA),
# Axis styling
axis.text = element_text(size = 9, color = "grey40", face = "bold"),
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.title.y = element_text(size = 11, face = "bold", color = "grey30", margin = margin(r = 15)),
# Legend styling
legend.position = "right",
legend.title = element_text(face = "bold", size = 10),
legend.text = element_text(size = 9),
legend.background = element_rect(fill = "#f2f2f2", color = NA),
legend.key = element_rect(fill = "#f2f2f2", color = NA),
# Increase the size of the dots in the legend so the colors are easy to see
legend.guides = guide_legend(override.aes = list(size = 5)),
# Titles
plot.title = element_text(size = 22, face = "bold", color = "black", hjust = 0.5, margin = margin(b = 8)),
plot.subtitle = element_markdown(size = 12, color = "grey40", hjust = 0.5, lineheight = 1.3, margin = margin(b = 25)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, color = "grey50", hjust = 1),
plot.margin = margin(30, 30, 30, 30)
)
