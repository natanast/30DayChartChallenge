# load real data ------
# We use the official Our World In Data CO2 dataset (live from their GitHub)
url <- "https://raw.githubusercontent.com/owid/co2-data/master/owid-co2-data.csv"
co2_raw <- fread(url)
# clean data & calculate waterfall logic ------
# 1. Filter for the World totals in 2020 and 2021
df_world <- co2_raw[country == "World" & year %in% c(2020, 2021),
.(year, co2, coal_co2, oil_co2, gas_co2, cement_co2, flaring_co2)]
# 2. Calculate the year-over-year differences (The "Causes" of the rebound)
diffs <- df_world[year == 2021, .(coal_co2, oil_co2, gas_co2, cement_co2, flaring_co2)] -
df_world[year == 2020, .(coal_co2, oil_co2, gas_co2, cement_co2, flaring_co2)]
# 3. Build the sequential Waterfall steps
df <- data.table(
cause = c("2020 Global Emissions\n(Pandemic Low)", "Coal Rebound", "Oil Rebound",
"Gas Rebound", "Cement & Flaring", "2021 Global Emissions\n(The Rebound)"),
change_mt = c(
df_world[year == 2020, co2],
diffs$coal_co2,
diffs$oil_co2,
diffs$gas_co2,
diffs$cement_co2 + diffs$flaring_co2,
NA # NA for the final total column
)
)
# Convert from Million Tonnes to Billion Tonnes for cleaner plot labels
df[, change := round(change_mt / 1000, 2)]
# 4. Standard Waterfall Math using data.table
df[, current_total := cumsum(fcoalesce(change, 0))]
df[, `:=`(
ymin = shift(current_total, n = 1, fill = 0),
ymax = current_total
)]
# The Final column should start at 0 and go up to the final total
final_val <- df[.N, ymax]
df[.N, `:=`(ymin = 0, change = final_val)]
# 5. Categorize for our color palette
df[, type := fcase(
cause %in% c("2020 Global Emissions\n(Pandemic Low)", "2021 Global Emissions\n(The Rebound)"), "Total Emissions",
change > 0, "Increase (Cause)",
change < 0, "Decrease"
)]
df[, cause := factor(cause, levels = cause)]
# Define color palette
col <- c(
"Total Emissions" = "#678e9f",
"Increase (Cause)" = "#b24745",
"Decrease" = "#81A88D"
)
# plot --------
gr = ggplot(df, aes(fill = type)) +
# Connecting dashed lines
geom_segment(
aes(x = as.numeric(cause) - 0.45, xend = as.numeric(cause) + 0.45,
y = ymax, yend = ymax),
color = "grey50", linetype = "dashed", linewidth = 0.4
) +
# Floating vertical bars
geom_rect(
aes(xmin = as.numeric(cause) - 0.4, xmax = as.numeric(cause) + 0.4,
ymin = ymin, ymax = ymax),
color = "grey10", linewidth = 0.3
) +
# Text labels showing the exact causal impact (in Billions)
geom_shadowtext(
aes(x = as.numeric(cause),
y = pmax(ymin, ymax) + 0.5,
label = ifelse(cause %like% "Total" | cause %like% "Emissions",
paste0(change, "B"),
paste0(ifelse(change > 0, "+", ""), change, "B"))),
color = "black", family = "Candara", bg.color = "grey93", bg.r = 0.1, size = 3.5, fontface = "bold"
) +
scale_fill_manual(values = col) +
# Expand Y axis so labels fit
scale_y_continuous(limits = c(0, max(df$ymax) + 2), expand = c(0, 0)) +
# Apply the text labels back to the numeric X axis
scale_x_continuous(
breaks = 1:length(levels(df$cause)),
labels = levels(df$cause)
) +
theme_minimal() +
labs(
title = "What **Caused** the 2021 Global Emissions Rebound?",
subtitle = "Following the 2020 pandemic dip, global CO₂ emissions surged by nearly 2 billion tonnes.<br>This waterfall isolates the specific fossil fuels that **caused** the increase.",
caption = "30DayChartChallenge 2026 | Day 16: Causation (Relationships) <br> Source: <b>Our World In Data (CO₂ dataset)</b> | Graphic: <b>Natasa Anastasiadou</b>",
y = "Global CO₂ Emissions (Billion Tonnes)"
) +
theme(
legend.position = "top",
legend.title = element_blank(),
legend.text = element_text(size = 9, family = "Candara", color = "grey30", face = "bold"),
legend.key.size = unit(0.8, "lines"),
axis.title.x = element_blank(),
axis.title.y = element_text(size = 9, family = "Candara", face = "bold", margin = margin(r = 10)),
axis.text.x = element_text(size = 8.5, family = "Candara", face = "bold", color = "grey20"),
axis.text.y = element_text(size = 8, family = "Candara"),
panel.grid.major.x = element_blank(),
panel.grid.minor = element_blank(),
panel.grid.major.y = element_line(color = "grey85", linewidth = 0.4),
