dt <- fread(url)
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
library(ggrepel)
library(gapminder) # Using the built-in package to avoid broken links!
# 1. Load data ------
dt <- as.data.table(gapminder)
# Filter for the most recent year in the dataset to make a clean scatter plot
dt_clean <- dt[year == 2007]
# 2. Create the Palette (Extracted from your reference image) -------
# Gapminder has 5 continents, which matches your 5 colors perfectly
cols <- c(
"Africa"   = "#b25c56",  # Dark Brick Red
"Americas" = "#e8998f",  # Soft Coral/Pink
"Asia"     = "#fcd4be",  # Pale Peach
"Europe"   = "#85aebc",  # Soft Slate Blue
"Oceania"  = "#4a6b7c"   # Dark Slate Blue
)
# 3. Plot --------
gr <- ggplot(dt_clean, aes(x = gdpPercap, y = lifeExp, color = continent, size = pop)) +
# Draw the bubbles! (alpha adds transparency so overlapping dots are visible)
geom_point(alpha = 0.85, stroke = 0) +
# Label a few extreme/interesting countries just like the reference image
geom_text_repel(data = dt_clean[country %in% c("Greece", "United States", "Japan", "Afghanistan", "South Africa", "Brazil", "China")],
aes(label = country),
family = "Candara", size = 3, color = "black",
box.padding = 0.8, point.padding = 0.3,
min.segment.length = 0, segment.color = "grey50", show.legend = FALSE) +
# Map the exact colors
scale_color_manual(values = cols, name = "Continent") +
# Log the X axis because GDP spans a massive range, and adjust bubble sizes
scale_x_log10(labels = scales::comma) +
scale_size_continuous(range = c(2, 18), guide = "none") + # Hide population legend to keep it clean
labs(
title = "The correlation of health and wealth",
subtitle = "Exploring the relationship between a country's GDP per capita and life expectancy.<br>Each bubble represents a country, sized by population.",
caption = "30DayChartChallenge 2026: <b> Day 15 (Correlation) </b> | Source: <b> Gapminder </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "GDP per Capita (Log Scale)",
y = "Life Expectancy (Years)"
) +
theme_minimal(base_family = "Candara") +
theme(
# Dashed gridlines on a light grey background to match the reference
panel.grid.major = element_line(color = "grey80", linetype = "dashed", linewidth = 0.4),
panel.grid.minor = element_blank(),
plot.background = element_rect(fill = "#f2f2f2", color = NA),
panel.background = element_rect(fill = "#f2f2f2", color = NA),
# Axis text styling
axis.text = element_text(size = 9, color = "grey40", face = "bold"),
axis.title.x = element_text(size = 10, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.title.y = element_text(size = 10, face = "bold", color = "grey30", margin = margin(r = 15)),
# Legend styling
legend.position = "right",
legend.title = element_text(face = "bold", size = 10),
legend.text = element_text(size = 9),
legend.background = element_rect(fill = "#f2f2f2", color = NA),
# Titles
plot.title = element_text(size = 20, face = "bold", color = "black", hjust = 0.5, margin = margin(b = 8)),
plot.subtitle = element_markdown(size = 11, color = "grey40", hjust = 0.5, lineheight = 1.2, margin = margin(b = 25)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, color = "grey50", hjust = 1),
plot.margin = margin(30, 30, 30, 30)
)
gr
