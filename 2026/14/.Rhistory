# 1. Load the Global Human Day data ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2023/2023-09-12/all_countries.csv"
dt <- fread(url)
# 2. Categorize 'Work' vs 'Rest' ------
# Based on the paper's methodology, we aggregate the specific categories
dt[, activity_type := fcase(
category %in% c("Food provision", "Nonfood provision", "Technosphere modification"), "Work",
category == "Somatic maintenance", "Rest", # This includes sleep, eating, and personal care
default = "Other"
)]
wdi_dt <- as.data.table(wdi_raw)
# 4. Merge the datasets ------
plot_dt <- merge(dt_wide, wdi_dt, by.x = "country_iso3", by.y = "iso3c")
# 1. Load data ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2020/2020-01-21/spotify_songs.csv"
dt <- fread(url)
# 2. Clean and Filter ------
# Capitalize the genres so they look nice in the legend
dt[, genre := fcase(
playlist_genre == "pop", "Pop",
playlist_genre == "rap", "Rap",
playlist_genre == "rock", "Rock",
playlist_genre == "latin", "Latin",
playlist_genre == "r&b", "R&B",
playlist_genre == "edm", "EDM"
)]
# Remove exact duplicates just in case a song is in multiple playlists
dt <- unique(dt, by = c("track_name", "track_artist"))
# Take the top 80 most popular tracks from EACH genre so the plot is balanced and not cluttered
dt_clean <- dt[order(-track_popularity), .SD[1:80], by = genre]
# Let's find the absolute #1 most popular song in each genre to label them automatically
top_labels <- dt_clean[order(-track_popularity), .SD[1], by = genre]
# 3. Create the Palette -------
# Expanded slightly from your 5 colors to fit the 6 Spotify genres,
# keeping the exact same quiet Mediterranean tones
cols <- c(
"Pop"   = "#b25c56",  # Dark Brick Red
"Rap"   = "#e8998f",  # Soft Coral
"Latin" = "#fcd4be",  # Pale Peach
"R&B"   = "#85aebc",  # Soft Slate Blue
"EDM"   = "#4a6b7c",  # Dark Slate Blue
"Rock"  = "#8aa39b"   # Sage Green (Added to balance the palette)
)
# 4. Plot --------
gr <- ggplot(dt_clean, aes(x = danceability, y = energy, color = genre, size = track_popularity)) +
# Draw the bubbles! (alpha adds transparency so overlapping dots are visible)
geom_point(alpha = 0.85, stroke = 0) +
# Automatically label the top song from each genre
geom_text_repel(data = top_labels,
aes(label = paste0(track_name, "\n(", track_artist, ")")),
family = "Candara", size = 3, color = "black", fontface = "bold",
lineheight = 0.9, box.padding = 1.2, point.padding = 0.3,
min.segment.length = 0, segment.color = "grey50", show.legend = FALSE) +
# Map the exact colors
scale_color_manual(values = cols, name = "Playlist Genre") +
# Size the bubbles by Popularity (0-100 scale)
scale_size_continuous(range = c(2, 9), name = "Track Popularity", breaks = c(70, 80, 90, 100)) +
labs(
title = "The anatomy of a hit song",
subtitle = "Correlating the danceability and energy of the top tracks across six major genres.<br>Notice how Rock clusters at high energy/lower danceability, while Rap and Latin dominate the dancefloor.",
caption = "30DayChartChallenge 2026: <b> Day 15 (Correlation) </b> | Source: <b> Spotify API </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "Danceability (0.0 to 1.0)",
y = "Energy (0.0 to 1.0)"
) +
theme_minimal(base_family = "Candara") +
theme(
# The reference image uses dashed gridlines on a light grey background
panel.grid.major = element_line(color = "grey80", linetype = "dashed", linewidth = 0.4),
panel.grid.minor = element_blank(),
plot.background = element_rect(fill = "#f2f2f2", color = NA),
panel.background = element_rect(fill = "#f2f2f2", color = NA),
# Axis styling
axis.text = element_text(size = 9, color = "grey40", face = "bold"),
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.title.y = element_text(size = 11, face = "bold", color = "grey30", margin = margin(r = 15)),
# Legend styling
legend.position = "right",
legend.title = element_text(face = "bold", size = 10),
legend.text = element_text(size = 9),
legend.background = element_rect(fill = "#f2f2f2", color = NA),
legend.key = element_rect(fill = "#f2f2f2", color = NA),
# Increase the size of the dots in the legend so the colors are easy to see
legend.guides = guide_legend(override.aes = list(size = 5)),
# Titles
plot.title = element_text(size = 22, face = "bold", color = "black", hjust = 0.5, margin = margin(b = 8)),
plot.subtitle = element_markdown(size = 11, color = "grey40", hjust = 0.5, lineheight = 1.3, margin = margin(b = 25)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, color = "grey50", hjust = 1),
plot.margin = margin(30, 30, 30, 30)
)
