library(data.table)
library(ggplot2)
library(ggridges)
library(ggtext)
library(extrafont)
# 1. Load data ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2020/2020-05-12/volcano.csv"
dt <- fread(url)
# 2. Clean and prep (Pure data.table!) ------
# Let's focus on the 5 most common physical structures
top_types <- dt[, .N, by = primary_volcano_type][order(-N)][1:5, primary_volcano_type]
dt_phys <- dt[primary_volcano_type %in% top_types]
# Clean up names for the plot
dt_phys[, type_clean := gsub("\\(s\\)", "", primary_volcano_type)]
# 3. Plot --------
gr <- ggplot(dt_phys, aes(x = elevation, y = type_clean, fill = type_clean)) +
# The Ridgeline (Joyplot) effect
geom_density_ridges(
alpha = 0.8,
color = "white",
scale = 1.5,
rel_min_height = 0.01,
linewidth = 0.4
) +
# A "Magma" inspired palette for a physical, volcanic feel
scale_fill_manual(values = c(
"Stratovolcano" = "#b24745",
"Shield" = "#db9044",
"Caldera" = "#5a8192",
"Volcanic field" = "#7f9faa",
"Pyroclastic cone" = "#a8b5b2"
)) +
labs(
title = "THE PHYSICAL STATURE OF VOLCANOES",
subtitle = "Distribution of **Elevation (m)** across the world's most common volcanic structures.<br>Notice how Stratovolcanoes dominate the higher physical altitudes.",
caption = "30DayChartChallenge 2026: <b> Day 11 (Distributions: Physical)</b> | Source: <b> Smithsonian Institution </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "Elevation (Meters above sea level)",
y = ""
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
axis.text.x = element_text(size = 11, face = "bold", color = "black"),
axis.text.y = element_text(size = 12, face = "bold", color = "black"),
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
panel.grid.major.x = element_line(linewidth = 0.3, color = "grey80", linetype = "dashed"),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
plot.title = element_text(size = 20, face = "bold", hjust = 0, margin = margin(t = 10, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0, color = "grey30", margin = margin(b = 20)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, hjust = 1, color = "grey40"),
plot.background = element_rect(fill = "#fdfcf0", color = NA), # "Old Map" parchment color
plot.margin = margin(20, 20, 20, 20)
)
gr
View(dt)
dt$primary_volcano_type |> uniqeu()
dt$primary_volcano_type |> unique()
top_types
View(dt_phys)
rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
# 1. Load data ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2020/2020-05-12/volcano.csv"
dt <- fread(url)
# 2. Clean and prep ------
# Get the 5 most common physical volcano types
top_types <- dt[, .N, by = primary_volcano_type][order(-N)][1:5, primary_volcano_type]
dt_phys <- dt[primary_volcano_type %in% top_types]
# Clean up the names (remove the "(s)")
dt_phys[, type_clean := gsub("\\(s\\)", "", primary_volcano_type)]
# DATA.TABLE MAGIC: Round the elevation to the nearest 250 meters so they overlap and stack!
dt_phys[, elevation_binned := round(elevation / 250) * 250]
# 3. Plot --------
gr <- ggplot(dt_phys, aes(x = type_clean, y = elevation_binned, color = type_clean)) +
# 1. Add the thin, elegant vertical "stems" matching your reference image
geom_segment(
aes(x = type_clean, xend = type_clean, y = min(elevation_binned), yend = max(elevation_binned)),
color = "grey85", linewidth = 0.5, alpha = 0.5
) +
# 2. The Counts Plot: geom_count automatically scales point size by the number of overlapping items
geom_count(alpha = 0.85) +
# Scale the bubble sizes so the biggest clusters really pop
scale_size_area(max_size = 14, name = "Number of\nVolcanoes") +
# A fiery, physical color palette
scale_color_manual(values = c(
"Stratovolcano" = "#b24745",
"Shield" = "#db9044",
"Caldera" = "#5a8192",
"Volcanic field" = "#7f9faa",
"Pyroclastic cone" = "#a8b5b2"
), guide = "none") + # Hide the color legend, keep only the size legend
labs(
title = "THE PHYSICAL STATURE OF VOLCANOES",
subtitle = "Distribution of global volcanoes by their physical structure and elevation.<br>Elevations are grouped into 250-meter intervals. **Larger bubbles indicate a higher concentration of volcanoes.**",
caption = "30DayChartChallenge 2026: <b> Day 11 (Distributions: Physical)</b> | Source: <b> Smithsonian Institution </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "",
y = "Elevation (Meters above sea level)"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "right",
legend.title = element_text(size = 10, face = "bold", color = "grey40"),
legend.text = element_text(size = 9, color = "grey30"),
axis.text.x = element_text(size = 12, face = "bold", color = "black", margin = margin(t = 10)),
axis.text.y = element_text(size = 10, face = "bold", color = "grey50"),
axis.title.y = element_text(size = 11, face = "bold", color = "grey30", margin = margin(r = 15)),
panel.grid.major.x = element_blank(), # We built custom stems, so we turn this off
panel.grid.major.y = element_line(linewidth = 0.3, color = "grey90", linetype = "dashed"),
panel.grid.minor = element_blank(),
plot.title = element_text(size = 20, face = "bold", hjust = 0, margin = margin(t = 10, b = 5)),
plot.subtitle = element_markdown(size = 11, hjust = 0, color = "grey30", lineheight = 1.2, margin = margin(b = 20)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, hjust = 1, color = "grey40"),
plot.background = element_rect(fill = "#fdfcf0", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
# 1. Load data ------
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2020/2020-05-12/volcano.csv"
dt <- fread(url)
# 2. Clean and prep ------
# FIX 1: Clean the text FIRST to merge "Stratovolcano" and "Stratovolcano(es)" into one category
dt[, type_clean := gsub("\\(es\\)|\\(s\\)", "", primary_volcano_type)]
# Now get the actual 5 most common volcano types
top_types <- dt[, .N, by = type_clean][order(-N)][1:5, type_clean]
dt_phys <- dt[type_clean %in% top_types]
# FIX 2: Change the binning from 250 to 500 meters.
# This means fewer vertical dots, and the bubbles will represent larger groups!
dt_phys[, elevation_binned := round(elevation / 500) * 500]
# 3. Plot --------
gr <- ggplot(dt_phys, aes(x = type_clean, y = elevation_binned, color = type_clean)) +
# The thin vertical stems
geom_segment(
aes(x = type_clean, xend = type_clean, y = min(elevation_binned), yend = max(elevation_binned)),
color = "grey85", linewidth = 0.5, alpha = 0.5
) +
# geom_count scales the size based on how many volcanoes are in that 500m bin
geom_count(alpha = 0.85) +
# Control the max size of the bubbles so they don't overlap horizontally
scale_size_area(max_size = 12, name = "Number of\nVolcanoes") +
# A fiery palette (using unnamed values so it automatically maps to the new clean top 5)
scale_color_manual(values = c("#b24745", "#db9044", "#5a8192", "#7f9faa", "#a8b5b2"), guide = "none") +
labs(
title = "THE PHYSICAL STATURE OF VOLCANOES",
subtitle = "Distribution of global volcanoes by their physical structure and elevation.<br>Elevations are grouped into 500-meter intervals. **Larger bubbles indicate a higher concentration.**",
caption = "30DayChartChallenge 2026: <b> Day 11 (Distributions: Physical)</b> | Source: <b> Smithsonian Institution </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "",
y = "Elevation (Meters above sea level)"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "right",
legend.title = element_text(size = 10, face = "bold", color = "grey40"),
legend.text = element_text(size = 9, color = "grey30"),
axis.text.x = element_text(size = 12, face = "bold", color = "black", margin = margin(t = 10)),
axis.text.y = element_text(size = 10, face = "bold", color = "grey50"),
axis.title.y = element_text(size = 11, face = "bold", color = "grey30", margin = margin(r = 15)),
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_line(linewidth = 0.3, color = "grey90", linetype = "dashed"),
panel.grid.minor = element_blank(),
plot.title = element_text(size = 20, face = "bold", hjust = 0, margin = margin(t = 10, b = 5)),
plot.subtitle = element_markdown(size = 11, hjust = 0, color = "grey30", lineheight = 1.2, margin = margin(b = 20)),
plot.caption = element_markdown(margin = margin(t = 20), size = 8, hjust = 1, color = "grey40"),
plot.background = element_rect(fill = "#fdfcf0", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
# 4. Save ---------
ggsave(
"Day11_Physical_CountsPlot_Fixed.png",
plot = gr,
width = 10,
height = 7,
dpi = 600
)
gr
# 3. Plot --------
