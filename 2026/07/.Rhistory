point_shape = 21,
point_size = 2,
point_color = "white",
point_fill = "grey20",
alpha = 0.8,
color = "white",
scale = 1.2
) +
scale_fill_manual(values = col) +
# THE MULTISCALE MAGIC:
scale_x_log10(
breaks = c(1, 10, 100, 1000, 10000),
labels = c("1 Hour", "10 Hrs", "100 Hrs", "1,000 Hrs\n(~40 Days)", "10,000 Hrs\n(~1 Year)"),
expand = expansion(mult = c(0.05, 0.1))
) +
labs(
title = "The Multiscale Duration of Human Spaceflight",
subtitle = "A logarithmic distribution of space mission durations.<br>Notice how Russian missions heavily cluster around the 10,000-hour mark due to long-term space station deployments.",
caption = "30DayChartChallenge 2026: <b> Day 7 (Distributions)</b> | Source: <b> The Astronaut Database / TidyTuesday </b> | Graphic: <b>Natasa Anastasiadou</b>",
y = "",
x = "Mission Duration (Logarithmic Scale)"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "none",
axis.title.x = element_text(size = 11, face = "bold", color = "grey30", margin = margin(t = 15)),
axis.text.y = element_text(size = 12, face = "bold", color = "black", vjust = 0),
axis.text.x = element_text(size = 10, face = "bold", color = "grey40"),
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey85", linetype = "dashed"),
panel.grid.minor.x = element_blank(),
panel.grid.major.y = element_blank(),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
ggsave(
plot = gr, filename = "Rplot.png",
width = 9, height = 9, units = "in", dpi = 600
)
rm(list = ls())
gc()
rm(list = ls())
gc()
# load libraries -------
library(data.table)
library(ggplot2)
library(ggtext)
library(extrafont)
# 1. Load data ------
# TidyTuesday: London Animal Rescues (June 2021)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2021/2021-06-29/animal_rescues.csv"
dt <- fread(url)
# 2. Clean data (NO INTERVENTION) ------
# The raw date format is "DD/MM/YYYY HH:MM". We extract just the Hour (0-23).
dt[, call_time := as.POSIXct(date_time_of_call, format="%d/%m/%Y %H:%M", tz="UTC")]
dt[, call_hour := as.numeric(format(call_time, "%H"))]
# Remove any rows with missing times
dt <- dt[!is.na(call_hour)]
# Automatically find the top 4 animals natively logged by the Fire Brigade
top_animals <- dt[, .N, by = animal_group_parent][order(-N)][1:4, animal_group_parent]
# Filter the dataset to just those 4 native categories
dt_plot <- dt[animal_group_parent %in% top_animals]
# Order them logically for the legend
dt_plot[, animal_group_parent := factor(animal_group_parent, levels = c("Cat", "Bird", "Dog", "Fox"))]
# Your editorial palette
col <- c(
"Cat"  = "#db9044",  # Sun Orange
"Bird" = "#7f9faa",  # Light Slate
"Dog"  = "#5a8192",  # Deep Steel Blue
"Fox"  = "#b24745"   # Terracotta Red
)
# 3. Plot --------
gr <- ggplot(dt_plot, aes(x = call_hour, fill = animal_group_parent, color = animal_group_parent)) +
# We use a density plot to show the smooth distribution of rescue calls
geom_density(alpha = 0.4, linewidth = 0.8) +
# THE CIRCULAR DISTRIBUTION MAGIC:
# This wraps the X-axis (0 to 24 hours) into a perfect continuous circle
coord_polar(start = 0) +
scale_fill_manual(values = col) +
scale_color_manual(values = col) +
# Format the axis to look like a 24-hour clock face
scale_x_continuous(
limits = c(0, 24),
breaks = seq(0, 23, by = 3),
labels = paste0(seq(0, 23, by = 3), ":00")
) +
# Remove the Y-axis labels so it looks like a pure radar/clock
scale_y_continuous(breaks = NULL) +
labs(
title = "The 24-Hour Rhythm of Animal Rescues",
subtitle = "A circular density distribution of emergency calls to the London Fire Brigade.<br>Notice how fox rescues surge at midnight, while bird rescues strictly follow daylight hours.",
caption = "30DayChartChallenge 2026: <b> Day 8 (Distributions: Circular)</b> | Source: <b> London.gov.uk / TidyTuesday </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "",
y = ""
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "right",
legend.title = element_blank(),
legend.text = element_text(size = 12, face = "bold", color = "grey30"),
# Format the clock face numbers
axis.text.x = element_text(size = 11, face = "bold", color = "grey40"),
# The gridlines become the "radar" rings and clock spokes
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey80", linetype = "dotted"),
panel.grid.major.y = element_line(linewidth = 0.4, color = "grey85", linetype = "solid"),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0.5, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
# 3. Plot --------
gr <- ggplot(dt_plot, aes(x = call_hour, fill = animal_group_parent, color = animal_group_parent)) +
# Increased alpha to 0.75 since they no longer overlap!
geom_density(alpha = 0.75, linewidth = 0.8) +
# THE FACET MAGIC: Creates a 2x2 grid of separate clocks
facet_wrap(~ animal_group_parent, ncol = 2) +
coord_polar(start = 0) +
scale_fill_manual(values = col) +
scale_color_manual(values = col) +
scale_x_continuous(
limits = c(0, 24),
breaks = seq(0, 23, by = 3),
labels = paste0(seq(0, 23, by = 3), ":00")
) +
scale_y_continuous(breaks = NULL) +
labs(
title = "The 24-Hour Rhythm of Animal Rescues",
subtitle = "Emergency calls to the London Fire Brigade, separated by animal type.<br>Notice how fox rescues surge at midnight, while bird rescues strictly follow daylight hours.",
caption = "30DayChartChallenge 2026: <b> Day 8 (Distributions: Circular)</b> | Source: <b> London.gov.uk / TidyTuesday </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "",
y = ""
) +
theme_minimal(base_family = "Candara") +
theme(
# Remove the legend entirely because the facet titles tell us what we are looking at
legend.position = "none",
# Style the facet titles (Cat, Bird, Dog, Fox)
strip.text = element_text(size = 14, face = "bold", color = "black", margin = margin(b = 10, t = 15)),
axis.text.x = element_text(size = 9, face = "bold", color = "grey50"),
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey80", linetype = "dotted"),
panel.grid.major.y = element_line(linewidth = 0.4, color = "grey85", linetype = "solid"),
# Add a little breathing room between the 4 clocks
panel.spacing = unit(2, "lines"),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0.5, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
# 1. Load data ------
# TidyTuesday: Global Volcanoes (May 2020)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2020/2020-05-12/volcano.csv"
dt <- fread(url)
# 2. Clean data ------
# We only need the raw, unmanipulated longitude coordinates
dt_plot <- dt[!is.na(longitude)]
# 3. Plot --------
gr <- ggplot(dt_plot, aes(x = longitude)) +
# Create a histogram with 5-degree bins of longitude
geom_histogram(
breaks = seq(-180, 180, by = 5),
fill = "#b24745",   # Terracotta/Magma color
color = "#e4e4e3",  # Matches the background to separate the bars crisply
linewidth = 0.3,
alpha = 0.9
) +
# THE CIRCULAR DISTRIBUTION MAGIC:
# start = pi rotates the circle so 0° (Prime Meridian / Europe) is at the bottom,
# and 180° (The Pacific Ocean / Ring of Fire) is at the top.
coord_polar(start = pi) +
# Format the axis to read like real geographic coordinates
scale_x_continuous(
limits = c(-180, 180),
breaks = seq(-150, 180, by = 30),
labels = c("150°W", "120°W", "90°W", "60°W", "30°W", "0°",
"30°E", "60°E", "90°E", "120°E", "150°E", "180°")
) +
# Remove the Y-axis rings/numbers to keep it looking like a pure geographic radar
scale_y_continuous(breaks = NULL) +
labs(
title = "The Pacific Ring of Fire",
subtitle = "A circular histogram of global volcanoes mapped by their exact longitude.<br>Notice the massive concentration of volcanic activity clustering around the Pacific Ocean.",
caption = "30DayChartChallenge 2026: <b> Day 8 (Distributions: Circular)</b> | Source: <b> Smithsonian Institution / TidyTuesday </b> | Graphic: <b>Natasa Anastasiadou</b>",
x = "",
y = ""
) +
theme_minimal(base_family = "Candara") +
theme(
# Style the geographic coordinate labels
axis.text.x = element_text(size = 10, face = "bold", color = "grey40"),
# The gridlines become the "spokes" pointing to different parts of the globe
panel.grid.major.x = element_line(linewidth = 0.4, color = "grey75", linetype = "dotted"),
panel.grid.major.y = element_blank(),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0.5, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 35), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
# 4. Save ---------
ggsave(
"Day8_Distributions_Circular_Volcanoes.png",
plot = gr,
width = 9,
height = 9, # Setting height equal to width ensures a perfectly round Earth!
dpi = 600
)
rm(list = ls())
gc()
# load libraries -------
library(tidyverse) # We need dplyr/tidyr for the complex angle calculations
library(ggtext)
library(extrafont)
# 1. Load data ------
# TidyTuesday: Spotify Songs (Jan 2020)
url <- "https://raw.githubusercontent.com/rfordatascience/tidytuesday/main/data/2020/2020-01-21/spotify_songs.csv"
dt <- read_csv(url, show_col_types = FALSE)
# 2. Clean and count the distributions ------
data <- dt %>%
mutate(
# Convert the binary mode into readable text
condition = ifelse(mode == 1, "Major Key", "Minor Key"),
# Capitalize the genres so they look nice on the plot
group = str_to_title(playlist_genre),
name = str_to_title(playlist_subgenre)
) %>%
# Count the number of songs in each subgenre, stacked by Major/Minor
group_by(group, name, condition) %>%
summarise(value = n(), .groups = "drop") %>%
arrange(group, name, condition)
# 3. Trigonometry & Formatting (Adapted from R Graph Gallery) ------
# Set a number of 'empty bar' to add at the end of each group to create the gaps
empty_bar <- 2
nObsType <- nlevels(as.factor(data$condition))
# Add the empty lines to the dataset
to_add <- data.frame(matrix(NA, empty_bar * nlevels(as.factor(data$group)) * nObsType, ncol(data)))
colnames(to_add) <- colnames(data)
to_add$group <- rep(levels(as.factor(data$group)), each = empty_bar * nObsType)
data <- rbind(data, to_add)
data <- data %>% arrange(group, name)
data$id <- rep(seq(1, nrow(data) / nObsType), each = nObsType)
# Get the name and the y position of each label
label_data <- data %>%
group_by(id, name) %>%
summarize(tot = sum(value, na.rm = TRUE), .groups = "drop") %>%
filter(!is.na(name))
# Calculate the exact angle for the text labels
number_of_bar <- max(data$id)
angle <- 90 - 360 * (label_data$id - 0.5) / number_of_bar
label_data$hjust <- ifelse(angle < -90, 1, 0)
label_data$angle <- ifelse(angle < -90, angle + 180, angle)
# Prepare base lines for the 6 Genre group labels
base_data <- data %>%
filter(!is.na(value)) %>%
group_by(group) %>%
summarize(start = min(id), end = max(id), .groups = "drop") %>%
rowwise() %>%
mutate(title = mean(c(start, end)))
# Your editorial palette for the stacks
col <- c(
"Major Key" = "#5a8192", # Slate Blue
"Minor Key" = "#db9044"  # Sun Orange
)
# 4. Plot --------
gr <- ggplot(data) +
# Add the stacked bars
geom_bar(aes(x = as.factor(id), y = value, fill = condition), stat = "identity", alpha = 0.9) +
scale_fill_manual(values = col) +
# Add the base line underneath each group
geom_segment(data = base_data, aes(x = start, y = -100, xend = end, yend = -100), colour = "grey50", alpha = 0.8, linewidth = 0.8) +
# Add the 6 major Genre labels
geom_text(data = base_data, aes(x = title, y = -400, label = group), hjust = 0.5, colour = "black", alpha = 0.9, size = 4.5, fontface = "bold", family = "Candara") +
# Add the 24 Subgenre labels, utilizing the calculated angles
geom_text(data = label_data, aes(x = id, y = tot + 100, label = name, hjust = hjust), color = "grey20", fontface = "bold", alpha = 0.8, size = 3, angle = label_data$angle, family = "Candara", inherit.aes = FALSE) +
# Define the limits of the Y axis. A negative bottom limit creates the empty "donut hole" in the center!
ylim(-1500, max(label_data$tot, na.rm = TRUE) + 800) +
# THE CIRCULAR DISTRIBUTION MAGIC
coord_polar() +
labs(
title = "The Circular Distribution of Musical Keys",
subtitle = "Comparing Major vs. Minor keys across 30,000 Spotify tracks and 24 subgenres.<br>Notice how EDM heavily favors minor keys, while classic rock is dominated by major keys.",
caption = "30DayChartChallenge 2026: <b> Day 8 (Distributions: Circular)</b> | Source: <b> Spotify / TidyTuesday </b> | Graphic: <b>Natasa Anastasiadou</b>"
) +
theme_minimal(base_family = "Candara") +
theme(
legend.position = "top",
legend.title = element_blank(),
legend.text = element_text(size = 11, face = "bold", color = "grey30"),
legend.margin = margin(b = 20),
# Remove standard gridlines and axes since we manually drew our own!
axis.text = element_blank(),
axis.title = element_blank(),
panel.grid = element_blank(),
plot.title = element_markdown(size = 18, face = "bold", hjust = 0.5, margin = margin(t = 15, b = 5)),
plot.subtitle = element_markdown(size = 12, hjust = 0.5, color = "grey30", margin = margin(t = 2.5, b = 25)),
plot.caption = element_markdown(margin = margin(t = 10, b = 10), size = 8, hjust = 1, lineheight = 1.2),
plot.background = element_rect(fill = "#e4e4e3", color = NA),
plot.margin = margin(20, 20, 20, 20)
)
gr
base_data
data
